  "keyFeatures": [
    "Event-driven workflow orchestration",
    "Service-oriented architecture integration",
    "Cloud-agnostic and vendor-neutral",
    "Fault tolerance with retry and error handling",
    "CRON-based and event-based scheduling",
    "Support for HTTP, gRPC, OpenAPI, AsyncAPI",
    "Runtime expressions with jq and JavaScript",
    "Extensible with custom functions and catalogs"
  ],
  "publicApiSurface": [
    "Workflow definition (document, use, do, schedule, timeout, input, output)",
    "Task types (call, do, emit, for, fork, listen, raise, run, set, switch, try, wait)",
    "Call protocols (HTTP, gRPC, OpenAPI, AsyncAPI, A2A, MCP)",
    "Authentication schemes (Basic, Bearer, Certificate, Digest, OAuth2, OIDC)",
    "Error handling (error definitions, retry policies, try-catch)",
    "Event handling (event filters, consumption strategies, correlation)",
    "Runtime expressions (jq, JavaScript)",
    "Catalogs (function catalogs, external resources)",
    "Extensions (custom functions, non-standard interactions)",
    "Lifecycle events (workflow and task lifecycle hooks)",
    "Process execution (container, shell, script, workflow)",
    "Flow directives (continue, exit, end)",
    "Timeout configuration (workflow-level, task-level)",
    "Data flow (input, output, export, filters)",
    "External resources (authentication policies, schemas)"
  ]
}
